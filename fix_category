def fix_category(item):
    name = item.get("name", "").lower()
    # Сначала исключения: слова, которые не должны быть "еда"
    if any(word in name for word in ["медаль", "жетон", "печатка", "рунный ключ", "линзы", "ритуальный нож", "татуировка", "язык пламени"]):
        return "снаряжение"
    # Зелья
    if "зелье" in name:
        return "зелье"
    # Свитки
    if "свиток" in name:
        return "свиток"
    # Книги/карты
    if any(k in name for k in ["книга", "карта", "дневник"]):
        return "книги/карты"
    # Оружие
    if any(k in name for k in ["меч", "лук", "топор", "кинжал", "копье", "арбалет", "булава", "плеть", "палица"]):
        return "оружие"
    # Броня
    if any(k in name for k in ["кольчуга", "латы", "доспех", "щит"]):
        return "броня"
    # Инструменты
    if "инструмент" in name or "набор" in name:
        return "инструменты"
    # Одежда
    if any(k in name for k in ["плащ", "сапоги", "одежда", "шляпа", "рубашка", "перчатки", "туфли"]):
        return "одежда"
    # Еда/напитки
    if any(k in name for k in ["еда", "пиво", "эль", "хлеб", "пирог", "жаркое", "буханка", "булочка"]):
        return "еда/напитки"
    # Транспорт
    if any(k in name for k in ["фургон", "повозка", "колесо"]):
        return "транспорт"
    # Услуги
    if any(k in name for k in ["стрижка", "баня", "ночлег"]):
        return "услуга"
    # Материалы
    if any(k in name for k in ["камень", "шкура", "мех", "плита"]):
        return "материалы"
    return "снаряжение"
